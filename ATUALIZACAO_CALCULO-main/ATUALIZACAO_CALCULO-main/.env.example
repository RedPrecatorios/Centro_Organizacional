HOST='127.0.0.1'
DB='flaskdb'
USER='seu_user_mysql'
PASS='sua_senha_mysql'

# (Opcional) Memória de cálculo (MySQL da plataforma)
MEMORIA_MYSQL_HOST='127.0.0.1'
MEMORIA_MYSQL_PORT=3306
MEMORIA_MYSQL_DATABASE="sistema_organizacional"
MEMORIA_MYSQL_USER="user_memoria"
MEMORIA_MYSQL_PASSWORD="senha_memoria"

# LibreOffice headless (Linux)
MEMORIA_LIBREOFFICE=1
MEMORIA_LIBREOFFICE_BIN=/usr/bin/soffice
MEMORIA_LIBREOFFICE_HOME=/var/lib/lo-calc

# Google Drive (Shared Drive recomendado para service account)
GOOGLE_DRIVE_ENABLED=1
GOOGLE_DRIVE_DATED_SUBFOLDERS=1
GOOGLE_DRIVE_FOLDER_ID=SEU_FOLDER_ID
GOOGLE_DRIVE_DATE_FORMAT=%d-%m-%Y
GOOGLE_DRIVE_TZ=America/Sao_Paulo
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=/caminho/absoluto/para/service-account.json
