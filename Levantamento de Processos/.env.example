# Webshare rotating proxy
WEBSHARE_PROXY_HOST=p.webshare.io
WEBSHARE_PROXY_PORT=80
WEBSHARE_PROXY_USERNAME=eleazile-rotate
WEBSHARE_PROXY_PASSWORD=

# Browser
HEADLESS=true
BROWSER_TIMEOUT_SECONDS=180
PAGE_LOAD_WAIT_SECONDS=4
# Optional absolute path to chrome.exe / chromium (needed on Windows)
# CHROME_BINARY=C:\Program Files\Google\Chrome\Application\chrome.exe

# Default e-SAJ search (override via CLI)
ESAJ_SEARCH_URL=https://esaj.tjsp.jus.br/cpopg/search.do?conversationId=&cbPesquisa=NMPARTE&dadosConsulta.valorConsulta=NADIR+COSTA+DE+OLIVEIRA&chNmCompleto=true&cdForo=-1

# REFACTOR_TJSP-main integration
# Linux server: /opt/PROJETO_ALEXA/REFACTOR_TJSP-main
# Windows local: C:\Users\<user>\Downloads\REFACTOR_TJSP-main
REFACTOR_TJSP_PATH=
REFACTOR_MODE=preenchimento
# CLI default; the HTTP API forces persistence + no --test regardless of this flag
REFACTOR_TEST_MODE=true

# Canonical final artifacts (JSON / parsing / depre / …)
# Linux: /opt/PROJETO_ALEXA/output  |  Windows: .\output next to this project
FINAL_OUTPUT_DIR=

# REFACTOR .env passthrough (written to REFACTOR if missing)
FLASK_DB_HOST=
FLASK_DB_PORT=3306
FLASK_DB_USER=
FLASK_DB_PASSWORD=
FLASK_DB_DATABASE=flaskdb
PREENCHIMENTO_SQL=SELECT id, numero_de_processo, numero_do_incidente FROM controle_coleta_TJSP LIMIT 1
GEMINI_API_KEY=
USE_GEMINI_API=

# Persistence: API search jobs set ENABLE_PERSISTENCE=true when enriching new cases
ENABLE_PERSISTENCE=false

# Calculo API (optional). When URL+TOKEN are set, API enables USE_CALCULO_API for new cases.
CALCULO_API_URL=
CALCULO_API_TOKEN=
USE_CALCULO_API=
CALCULO_API_TIMEOUT=90

# HTTP API
API_HOST=0.0.0.0
API_PORT=8000
# Shared secret with the cloud client (Authorization: Bearer <token> or X-API-Token)
API_TOKEN=change-me-to-a-long-random-secret

# Output
LOG_DIR=logs
DEBUG_HTML_DIR=logs/debug_html
